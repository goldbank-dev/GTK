{
  "name": "gtk",
  "version": "1.0.0",
  "description": "Gold Token (GTK) - ERC-20 token backed 1:1 by physical gold",
  "main": "GTK_BankAPI.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test tests/unit/",
    "test:fork": "hardhat test --fork",
    "test:api": "jest tests/api/ --forceExit --detectOpenHandles",
    "test:dashboard": "jest tests/dashboard/ --forceExit",
    "test:e2e": "jest tests/e2e/ --forceExit",
    "test:all": "jest tests/api/ tests/dashboard/ tests/e2e/ --forceExit --detectOpenHandles",
    "test:full": "npm test && jest tests/api/ tests/dashboard/ tests/e2e/ --forceExit --detectOpenHandles",
    "deploy:sepolia": "hardhat run scripts/deploy/testnet-deploy.ts --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy/mainnet-deploy.ts --network mainnet",
    "deploy:mainnet:prod": "cross-env DOTENV_CONFIG_PATH=.env.production.final hardhat run scripts/deploy/mainnet-deploy.ts --network mainnet",
    "verify": "hardhat verify",
    "gas": "hardhat test --gas",
    "coverage": "hardhat coverage",
    "lint": "solhint contracts/**/*.sol",
    "lint:js": "eslint src/ tests/",
    "typechain": "hardhat typechain",
    "clean": "hardhat clean",
    "start": "node src/api/server.js",
    "start:staging": "cross-env NODE_ENV=staging node src/api/server.js",
    "start:prod": "cross-env NODE_ENV=production node src/api/server.js",
    "dev": "nodemon src/api/server.js",
    "dashboard": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amos-fernandes/GTK.git"
  },
  "keywords": [
    "gold",
    "token",
    "real-world-assets",
    "rwa",
    "ethereum"
  ],
  "author": "GTK Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/amos-fernandes/GTK/issues"
  },
  "homepage": "https://github.com/amos-fernandes/GTK#readme",
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.7.0",
    "babel-jest": "^30.4.1",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "solhint": "^5.0.0",
    "solidity-coverage": "^0.8.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "winston": "^3.19.0"
  }
}
